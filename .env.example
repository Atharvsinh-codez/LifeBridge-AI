# LifeBridge AI — Environment Variables
# Local dev: copy to .env and fill in your values
# Production (Render): set these in Dashboard → Environment

# ── App URLs ──
# On Render: set to your deployed URLs, e.g. https://lifebridge-web.onrender.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# ── API Server ──
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
# On Render: set to your production web URL
ALLOWED_ORIGINS=http://localhost:3000
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
GUEST_SESSION_JWT_SECRET=

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ── Lingo.dev (Translation) ──
LINGO_API_KEY=
LINGO_ENGINE_ID=

# ── Gemini (AI + TTS) ──
GEMINI_API_KEY=
GEMINI_CONTEXT_MODEL=gemini-2.5-flash
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
