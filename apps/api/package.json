{
  "name": "@lifebridge/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "build": "tsup src/server.ts --format esm --sourcemap --clean",
    "start": "node dist/server.js",
    "lint": "tsc --project tsconfig.json --noEmit",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@lifebridge/config": "workspace:*",
    "@lifebridge/emergency-knowledge": "workspace:*",
    "@lifebridge/prompts": "workspace:*",
    "@lifebridge/shared": "workspace:*",
    "@lifebridge/validation": "workspace:*",
    "@supabase/supabase-js": "^2.49.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lingo.dev": "^0.133.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "ws": "^8.18.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.10",
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}